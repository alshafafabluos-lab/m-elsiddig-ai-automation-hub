rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email_verified == true && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        request.auth.token.email == 'alshafafabluos@gmail.com'
      ); 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Registrations
    match /registrations/{regId} {
      function isValidRegistration(data) {
        return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 200 &&
               data.email is string && data.email.size() > 0 && data.email.size() < 200 &&
               data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
               data.age is number && data.age > 0 && data.age < 120 &&
               data.profession is string && data.profession.size() > 0 &&
               data.field is string && data.field.size() > 0 &&
               data.aiInterest is string && data.aiInterest.size() > 0 &&
               data.createdAt == request.time &&
               data.status == 'pending';
      }

      allow create: if isValidRegistration(request.resource.data) && isValidId(regId);
      allow get, list, update, delete: if isAdmin();
    }

    // Settings
    match /settings/workshop {
      allow read: if true; // Public can see if it's active
      allow write: if isAdmin();
    }
  }
}
